---
import Base from '../layouts/Base.astro';
import { Content, frontmatter } from '../data/home.md';
import running from '../data/running.json';
import bannerArt from '../data/banner.txt?raw'; // figlet "Standard" of "fenn.md" (see src/data/banner.txt)
import coconutArt from '../data/coconut.txt?raw'; // `cat cat` easter egg — ASCII of Coconut the cat
import '../styles/brutal.css';

const { name, role, tagline, links } = frontmatter;
const shellData = { name, role, tagline, links, streak: running.streakDays, miles: running.streakMiles, rest: running.restDays, coconut: coconutArt };
---

<Base title={`${name} — shell`} description={tagline}>
  <main class="wrap termwrap">
    <a class="b-btn back" href="/">← back to fenn.md</a>

    <section class="window" aria-label="Terminal">
      <header class="winbar">
        <span class="dots"><i></i><i></i><i></i></span>
        <span class="wintitle">alex@fenn.md — zsh</span>
        <span class="spacer"></span>
      </header>

      <div class="screen" id="screen">
        <pre class="banner">{bannerArt}</pre>
        <p class="banner-sub">// alex fenn, md — emergency medicine + clinical informatics</p>

        <div id="log">
          <div class="line"><span class="prompt">alex@fenn.md ~ %</span> <span class="cmd">whoami</span></div>
          <div class="out">{name} — {role}</div>

          <div class="line"><span class="prompt">alex@fenn.md ~ %</span> <span class="cmd">cat about.md</span></div>
          <div class="out prose-t" id="about-src"><Content /></div>

          <div class="line"><span class="prompt">alex@fenn.md ~ %</span> <span class="cmd">run --streak</span></div>
          <div class="out">🏃 {running.streakDays.toLocaleString('en-US')}-day streak · {running.streakMiles.toLocaleString('en-US')} mi · {running.restDays} rest days</div>

          <div class="out links" id="links-src">
            {links.map((l: { label: string; href: string }) => <a href={l.href}>{l.label}</a>)}
          </div>

          <p class="hint">Type <b>help</b> and press ⏎ — or try <b>run</b> | <b>links</b> | <b>ls</b> | <b>clear</b>.</p>
        </div>

        <div class="line input-line">
          <span class="prompt">alex@fenn.md ~ %</span>
          <input id="cmd" class="cmd-input" type="text" autocomplete="off" autocapitalize="off"
            autocorrect="off" spellcheck="false" aria-label="Terminal command input" />
        </div>
      </div>
    </section>
  </main>

  <script type="application/json" id="shell-data" set:html={JSON.stringify(shellData)} />
</Base>

<script>
  const screen = document.getElementById('screen')!;
  const log = document.getElementById('log')!;
  const input = document.getElementById('cmd') as HTMLInputElement;
  const data = JSON.parse(document.getElementById('shell-data')!.textContent || '{}');
  const aboutText = document.getElementById('about-src')?.textContent?.trim() ?? '';

  const PROMPT = 'alex@fenn.md ~ %';
  const history: string[] = [];
  let histIndex = -1;
  const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  type Cmd = (args: string[]) => string;
  const commands: Record<string, Cmd> = {
    help: () =>
      'commands:  whoami | about | cat <file> | run | links | contact | ls | clear\n(…and a few undocumented ones — go exploring)',
    whoami: () => `${data.name} — ${data.role}`,
    about: () => aboutText,
    cat: (args) => {
      const f = (args[0] || '').toLowerCase().replace(/^\.\//, '');
      if (!f) return 'usage: cat <file>   (try: cat about.md)';
      if (f === 'about.md' || f === 'about') return aboutText;
      // (cat cat / cat coconut is intercepted in run() so it can render as pre-formatted art)
      return `cat: ${args[0]}: No such file or directory`;
    },
    run: () =>
      `🏃 ${Number(data.streak).toLocaleString('en-US')}-day run streak · ${Number(data.miles).toLocaleString('en-US')} mi · ${data.rest} rest days`,
    ls: () => 'about.md   links   run   contact',
    links: () =>
      data.links
        .map((l: { label: string; href: string }) => `  ${l.label.padEnd(10)} <a href="${esc(l.href)}">${esc(l.href)}</a>`)
        .join('\n'),
    contact: () => commands.links([]),
    // hidden commands (not listed in `help`) — for the curious
    coffee: () => 'Hario V60 daily driver, sometimes an Aeropress.\nRoasters I like: Sweet Bloom | Little Waves | Brandywine | S&W Craft Roasting',
    sudo: (args) =>
      /sandwich/i.test(args.join(' ')) ? 'okay. 🥪  (xkcd.com/149)' : "nice try — you don't have root on fenn.md 🙂",
    fortune: () => '“The systems around the care can be as healing as the care itself.”',
  };
  // commands that emit HTML (links) rather than escaped text
  const HTML_CMDS = new Set(['links', 'contact']);

  function emit(html: string, cls = 'out') {
    const div = document.createElement('div');
    div.className = cls;
    div.innerHTML = html;
    log.appendChild(div);
  }

  // hidden animated easter egg: `sl` (the classic ls typo) or `run --far` → go for a run 🏃
  function runnerEgg() {
    const lane = document.createElement('div');
    lane.className = 'out';
    lane.style.whiteSpace = 'pre';
    log.appendChild(lane);
    const W = 32;
    let pos = 0;
    const timer = window.setInterval(() => {
      if (pos > W) {
        window.clearInterval(timer);
        lane.textContent = '·'.repeat(W) + '🏃';
        emit(`day ${Number(data.streak).toLocaleString('en-US')} in the bag. keep the streak alive.`);
        screen.scrollTop = screen.scrollHeight;
        return;
      }
      lane.textContent = '·'.repeat(pos) + '🏃';
      pos++;
      screen.scrollTop = screen.scrollHeight;
    }, 45);
  }

  function run(raw: string) {
    const cmd = raw.trim();
    const echo = document.createElement('div');
    echo.className = 'line';
    echo.innerHTML = `<span class="prompt">${PROMPT}</span> <span class="cmd">${esc(cmd)}</span>`;
    log.appendChild(echo);
    if (!cmd) return;
    history.push(cmd);
    histIndex = history.length;

    const [base, ...args] = cmd.split(/\s+/);
    const key = base.toLowerCase();

    if (key === 'clear') { log.replaceChildren(); return; }
    if (key === 'sl' || (key === 'run' && /--(far|ultra|forever)/.test(args.join(' ')))) { runnerEgg(); return; }
    // `cat cat` (or cat.md / coconut) → ASCII art of Coconut, rendered pre-formatted
    if (key === 'cat' && ['cat', 'cat.md', 'coconut', 'coconut.md'].includes((args[0] || '').toLowerCase().replace(/^\.\//, ''))) {
      emit(esc(data.coconut), 'out art');
      return;
    }

    const fn = commands[key];
    if (fn) {
      emit(HTML_CMDS.has(key) ? fn(args) : esc(fn(args)));
    } else {
      emit(`zsh: command not found: ${esc(base)} — try <b>help</b>`, 'out err');
    }
  }

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      run(input.value);
      input.value = '';
      screen.scrollTop = screen.scrollHeight;
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (histIndex > 0) input.value = history[--histIndex] ?? '';
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (histIndex < history.length - 1) input.value = history[++histIndex] ?? '';
      else { histIndex = history.length; input.value = ''; }
    }
  });
  screen.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).tagName !== 'A' && !window.getSelection()?.toString()) input.focus();
  });
  input.focus({ preventScroll: true });
</script>

<style>
  .termwrap { padding-top: 2rem; padding-bottom: 4rem; max-width: 52rem; }
  .back { margin-bottom: 1.5rem; }

  .window {
    border: var(--line);
    box-shadow: var(--shadow);
    background: #0c0e12;
    overflow: hidden;
  }
  .winbar {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.65rem 0.9rem;
    background: var(--paper);
    border-bottom: var(--line);
  }
  .dots { display: inline-flex; gap: 0.4rem; }
  .dots i { width: 12px; height: 12px; border-radius: 50%; border: 2px solid var(--ink); }
  .dots i:nth-child(1) { background: #ff5f57; }
  .dots i:nth-child(2) { background: #febc2e; }
  .dots i:nth-child(3) { background: #28c840; }
  .wintitle { font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600; }
  .spacer { flex: 1; }

  .screen {
    --t-accent: #7d9bff;
    --t-pink: #ff7a93;
    font-family: var(--font-mono);
    font-size: clamp(0.82rem, 0.78rem + 0.2vw, 0.92rem);
    line-height: 1.65;
    color: #cdd3e0;
    padding: 1.2rem 1.3rem 1.4rem;
    height: min(66vh, 38rem);
    overflow-y: auto;
    cursor: text;
  }
  .banner { color: var(--t-accent); font-size: 0.66rem; line-height: 1.2; margin: 0 0 0.5rem; white-space: pre; overflow-x: auto; }
  .banner-sub { color: var(--t-accent); opacity: 0.65; font-size: 0.72rem; margin: 0 0 1.2rem; }
  /* Output is appended by JS, so those nodes don't carry Astro's scope hash —
     anchor the styles globally under the (scoped) #screen so typed-command output
     gets the same treatment as the server-rendered transcript. */
  #screen :global(.line) { white-space: pre-wrap; word-break: break-word; }
  #screen :global(.prompt) { color: var(--t-accent); user-select: none; }
  #screen :global(.cmd) { color: #fff; }
  #screen :global(.out) { white-space: pre-wrap; word-break: break-word; margin: 0.15rem 0 1rem; color: #aab2c5; }
  #screen :global(.out.err) { color: var(--t-pink); }
  #screen :global(.out.art) { white-space: pre; overflow-x: auto; line-height: 1.25; color: var(--t-accent); }
  .prose-t :global(p) { margin: 0 0 0.7rem; }
  .prose-t :global(p:last-child) { margin-bottom: 0; }
  .prose-t :global(strong) { color: #fff; font-weight: 500; }
  .prose-t :global(em) { color: var(--t-accent); font-style: normal; }
  .links { display: flex; flex-wrap: wrap; gap: 0.4rem 1.3rem; }
  #screen :global(.out a), .links a { color: var(--t-accent); text-decoration: none; border-bottom: 1px solid transparent; }
  #screen :global(.out a:hover), .links a:hover { border-bottom-color: var(--t-accent); }
  .hint { color: #6f7891; margin: 0.4rem 0 1.1rem; }
  .hint b { color: var(--t-accent); font-weight: 500; }
  .input-line { display: flex; align-items: baseline; gap: 0.5ch; }
  .cmd-input { flex: 1; appearance: none; background: transparent; border: 0; outline: 0; color: #fff; font: inherit; caret-color: var(--t-pink); padding: 0; }
  .screen::-webkit-scrollbar { width: 10px; }
  .screen::-webkit-scrollbar-thumb { background: rgba(125, 155, 255, 0.3); }
</style>
