---
import Base from '../layouts/Base.astro';
import { Content, frontmatter } from '../data/home.md';
// The literal file text, so "raw" shows the real source — not a copy.
import rawSource from '../data/home.md?raw';
import '../styles/brutal.css';

const { name, role, tagline, links } = frontmatter;
---

<Base title={`${name} — view source`} description={tagline}>
  <main class="wrap srcwrap">
    <a class="b-btn back" href="/">← back to fenn.md</a>

    <div class="window b-card" data-view="rendered">
      <span class="b-tab">~/fenn.md/home.md</span>
      <div class="bar">
        <span class="hint">this page, two ways</span>
        <div class="toggle" role="tablist" aria-label="View mode">
          <button data-mode="rendered" class="is-active" role="tab" aria-selected="true">rendered</button>
          <button data-mode="raw" role="tab" aria-selected="false">raw .md</button>
        </div>
      </div>

      <article class="rendered doc">
        <h1>{name}</h1>
        <p class="role">{role}</p>
        <p class="tagline">{tagline}</p>
        <div class="prose"><Content /></div>
        <nav class="links">
          {links.map((l: { label: string; href: string }) => <a href={l.href}>{l.label} ↗</a>)}
        </nav>
      </article>

      <pre class="raw"><code>{rawSource}</code></pre>
    </div>
  </main>
</Base>

<script>
  const win = document.querySelector<HTMLElement>('.window');
  const buttons = document.querySelectorAll<HTMLButtonElement>('.toggle button');
  buttons.forEach((btn) =>
    btn.addEventListener('click', () => {
      if (win) win.dataset.view = btn.dataset.mode!;
      buttons.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-selected', String(on));
      });
    })
  );
</script>

<style>
  .srcwrap { padding-top: 2rem; padding-bottom: 4rem; max-width: 48rem; }
  .back { margin-bottom: 1.5rem; }

  .window { padding: 0; }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.4rem 1.3rem 0.9rem;
    border-bottom: var(--line);
  }
  .hint { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
  .toggle { display: inline-flex; border: 2px solid var(--ink); }
  .toggle button {
    appearance: none; border: 0; background: var(--panel); color: var(--ink);
    font-family: var(--font-mono); font-size: 0.76rem; font-weight: 600;
    padding: 0.4rem 0.7rem; cursor: pointer;
  }
  .toggle button + button { border-left: 2px solid var(--ink); }
  .toggle button.is-active { background: var(--accent); color: var(--paper); }

  .doc { padding: 1.6rem 1.4rem; font-family: var(--font-serif); }
  .doc h1 { font-family: var(--font-sans); font-weight: 700; font-size: clamp(1.8rem, 1.2rem + 2.4vw, 2.6rem); letter-spacing: -0.02em; margin: 0; text-transform: uppercase; }
  .doc .role { font-family: var(--font-mono); font-size: 0.82rem; color: var(--accent); font-weight: 600; margin: 0.4rem 0 0; }
  .doc .tagline { font-style: italic; font-size: 1.25rem; margin: 1rem 0 1.4rem; }
  .doc .prose { font-size: 1.08rem; line-height: 1.65; }
  .links { display: flex; flex-wrap: wrap; gap: 0.5rem 1.3rem; margin-top: 1.6rem; font-family: var(--font-mono); font-size: 0.85rem; }
  .links a { text-decoration: none; border-bottom: 2px solid var(--accent); }

  .raw {
    display: none;
    margin: 0;
    padding: 1.5rem 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.84rem;
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-word;
    background: #fbfaf6;
    color: #2b2b2b;
  }
  .window[data-view='raw'] .rendered { display: none; }
  .window[data-view='raw'] .raw { display: block; }
</style>
