---
// Shows a real headshot if one exists at src/assets/headshot.* — otherwise a
// clean "AF" monogram. To use a photo: drop headshot.jpg (or .png/.webp) into
// src/assets/ and rebuild. No broken image either way.
const monogram = 'AF';
const matches = import.meta.glob('../assets/headshot.*', {
  eager: true,
  query: '?url',
  import: 'default',
});
const headshot = Object.values(matches)[0] as string | undefined;

interface Props { size?: number; }
const { size = 96 } = Astro.props;
---

{headshot ? (
  <img class="avatar" src={headshot} width={size} height={size} alt="Alexander Fenn" />
) : (
  <span class="avatar avatar--monogram" style={`--size:${size}px`} aria-label="Alexander Fenn">{monogram}</span>
)}

<style>
  .avatar { border-radius: 50%; flex: none; }
  img.avatar { width: var(--size, 96px); height: auto; object-fit: cover; }
  .avatar--monogram {
    display: inline-grid;
    place-items: center;
    width: var(--size);
    height: var(--size);
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0.01em;
    font-size: calc(var(--size) * 0.36);
    color: var(--avatar-fg, #f8fafc);
    background: var(--avatar-bg, linear-gradient(135deg, #0ea5a4, #0f766e));
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.18);
    user-select: none;
  }
</style>
